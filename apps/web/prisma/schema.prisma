// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
    url = env("DATABASE_URL")
}


model StravaAccount {
  id              Int      @id @default(autoincrement())
  stravaAthleteId Int      @unique
  firstname       String?
  lastname        String?
  accessToken     String
  refreshToken    String
  expiresAt       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}



model StravaActivity {
  id                 Int      @id @default(autoincrement())
  stravaActivityId   BigInt   @unique
  stravaAthleteId    Int

  name               String?
  type               String?
  sportType          String?

  distance           Float?
  movingTime         Int?
  elapsedTime        Int?
  startDate          DateTime?
  timezone           String?

  averageSpeed       Float?
  maxSpeed           Float?
  averagePace        Float?
  averageHeartrate   Float?
  maxHeartrate       Float?
  averageCadence     Float?
  sufferScore        Int?

  totalElevationGain Float?
  elevHigh           Float?
  elevLow            Float?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

